{
  "name": "neonbinder",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:backend": "./dev-backend.sh",
    "dev:all": "concurrently \"vite\" \"./dev-backend.sh\"",
    "dev:backend:tunnel": "./dev-backend-tunnel.sh",
    "env:browser": "npx convex env set NEONBINDER_BROWSER_URL",
    "tunnel": "cloudflared tunnel --url http://localhost:8080",
    "predev:all": "./setup-env.sh",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint .",
    "builder": "npx builder.io@latest launch --app --serverUrl http://localhost:3000",
    "setup:e2e": "./setup-maestro.sh",
    "setup:e2e:signin": "./setup-maestro-signin.sh",
    "test:e2e": "PATH=$HOME/.maestro/bin:$PATH ./run-e2e-smoke.sh",
    "test:e2e:signin": "PATH=$HOME/.maestro/bin:$PATH maestro test --platform web --config .maestro/config.yaml -e APP_URL=${APP_URL:-http://localhost:3000} .maestro/flows/auth/sign-in.yaml",
    "test:e2e:dashboard": "PATH=$HOME/.maestro/bin:$PATH maestro test --platform web --config .maestro/config.yaml -e APP_URL=${APP_URL:-http://localhost:3000} .maestro/flows/dashboard/view-collection.yaml",
    "test:e2e:single": "maestro test --platform web --config .maestro/config.yaml -e APP_URL=${APP_URL:-http://localhost:3000} -e TEST_USERNAME=${TEST_USERNAME:-neontester_$(date +%s)}",
    "test:e2e:smoke": "PATH=$HOME/.maestro/bin:$PATH ./run-e2e-smoke.sh smoke",
    "test:e2e:ci": "PATH=$HOME/.maestro/bin:$PATH ./run-e2e-smoke.sh smoke",
    "postinstall": "husky install"
  },
  "dependencies": {
    "@clerk/backend": "^3.2.3",
    "@clerk/clerk-react": "^5.20.0",
    "@convex-dev/auth": "^0.0.81",
    "@google-cloud/storage": "^7.19.0",
    "@heroicons/react": "^2.2.0",
    "@radix-ui/themes": "^3.2.1",
    "@sentry/react": "^9.0.0",
    "@sentry/vite-plugin": "^3.0.0",
    "@types/crypto-js": "^4.2.2",
    "@vercel/blob": "^2.3.2",
    "axios": "^1.10.0",
    "convex": "^1.27.1",
    "convex-helpers": "^0.1.104",
    "crypto-js": "^4.2.0",
    "posthog-js": "^1.280.1",
    "posthog-node": "^5.28.8",
    "qr-scanner": "^1.4.2",
    "qrcode-generator": "^1.4.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router": "^7.0.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@tailwindcss/vite": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vercel/node": "^5.7.10",
    "@vitejs/plugin-basic-ssl": "^2.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "concurrently": "^9.0.0",
    "dotenv": "^16.6.1",
    "dotenv-cli": "^8.0.0",
    "eslint": "^9",
    "eslint-plugin-react-hooks": "^5.0.0",
    "husky": "^9.1.7",
    "localtunnel": "^2.0.2",
    "prettier": "^3.5.3",
    "tailwindcss": "^4.1.11",
    "typescript": "^5",
    "vite": "^6.0.0"
  }
}
